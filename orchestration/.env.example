# Copy to `.env` (gitignored) and fill in. Never commit a real key.
OPENAI_API_KEY=

# Optional — point at any OpenAI-compatible endpoint instead of OpenAI.
#   OpenRouter:      OPENAI_BASE_URL=https://openrouter.ai/api/v1   MODEL=openai/gpt-4o-mini
#   Cluster vLLM:    OPENAI_BASE_URL=http://<host>:8000/v1          MODEL=<served-model-name>
# OPENAI_BASE_URL=
# MODEL=gpt-4o-mini

# Optional run defaults (also settable via CLI flags).
# SEED=7
# MAX_EXCHANGES=6
